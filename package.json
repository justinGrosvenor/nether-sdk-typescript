{
  "name": "@nether/sdk",
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.0",
  "description": "TypeScript SDK for the nether sandbox control protocol: a high-level Sandbox facade plus the low-level wire codec and role clients. Zero runtime dependencies.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Justin Grosvenor",
  "homepage": "https://github.com/justinGrosvenor/nether-sdk-typescript#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/justinGrosvenor/nether-sdk-typescript.git"
  },
  "bugs": {
    "url": "https://github.com/justinGrosvenor/nether-sdk-typescript/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src test examples",
    "format": "biome format --write .",
    "check": "biome check src test examples && tsc --noEmit && vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "nether",
    "sandbox",
    "microvm",
    "control-protocol",
    "sdk"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/node": "^22.15.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
